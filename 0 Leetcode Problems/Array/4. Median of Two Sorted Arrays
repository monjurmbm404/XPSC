class Solution {
public:
    double findMedianSortedArrays(vector<int>& nums1, vector<int>& nums2) {
        int n = nums1.size();
        int m = nums2.size();
        int l = m+n;
        vector<int> ans;
        double median;

        for(int x : nums1) ans.push_back(x);
        for(int x : nums2) ans.push_back(x);

        sort(ans.begin(), ans.end());

        if(l % 2 == 0){
            int val = (ans[l/2] + ans[(l - 1)/2]);
            median = val/ 2;
            if(val % 2 == 1)
                median += 0.5;
        }else
            median = ans[l/2];

        return median;
    }
};